{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/health", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/cron/(.*)", "destination": "/api/index.ts" },
    { "source": "/proxy-image", "destination": "/api/index.ts" },
    { "source": "/robots.txt", "destination": "/api/index.ts" },
    { "source": "/sitemap.xml", "destination": "/api/index.ts" },
    { "source": "/article/(.*)", "destination": "/api/index.ts" },
    { "source": "/news/(.*)", "destination": "/api/index.ts" },
    { "source": "/about", "destination": "/api/index.ts" },
    { "source": "/privacy", "destination": "/api/index.ts" },
    { "source": "/archive", "destination": "/api/index.ts" },
    { "source": "/", "destination": "/api/index.ts" },
    { "source": "/index.html", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-newsletter",
      "schedule": "0 9 * * 1"
    }
  ]
}
