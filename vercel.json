{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/*",
          "dist/**/*",
          "src/services/*.ts",
          "package.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/server.ts",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    { "src": "/api/(.*)", "dest": "/server.ts" },
    { "src": "/article/(.*)", "dest": "/server.ts" },
    { "src": "/news/(.*)", "dest": "/server.ts" },
    { "src": "/(.*)", "dest": "/server.ts" }
  ]
}
