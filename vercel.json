{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/health", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/cron/(.*)", "destination": "/api/index.ts" },
    { "source": "/proxy-image", "destination": "/api/index.ts" },
    { "source": "/robots.txt", "destination": "/api/index.ts" },
    { "source": "/sitemap.xml", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
