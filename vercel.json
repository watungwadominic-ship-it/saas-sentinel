{
  "version": 2,
  "functions": {
    "server.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/assets/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/article/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/news/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/server.ts"
    }
  ]
}
