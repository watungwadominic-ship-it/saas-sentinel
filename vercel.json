{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "src/services/*.ts"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.ts" },
    { "src": "/assets/(.*)", "dest": "server.ts" },
    { "src": "/article/(.*)", "dest": "server.ts" },
    { "src": "/news/(.*)", "dest": "server.ts" },
    { "src": "/(.*)", "dest": "server.ts" }
  ]
}
