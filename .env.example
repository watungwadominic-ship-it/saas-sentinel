# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_USER_GEMINI_API_KEY: User-provided Gemini API key for client-side calls.
VITE_USER_GEMINI_API_KEY=

# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL="https://dpwkojtfeoxlpyevutfc.supabase.co"

# SUPABASE_KEY: Your Supabase service role or anon key
SUPABASE_KEY="sb_publishable_WumEuqpPeooXrt1nkO9l_w_zWa37BgE"

# NewsAPI Key: Get yours at https://newsapi.org/
NEWS_API_KEY=

# Groq API Key: Get yours at https://console.groq.com/keys
GROQ_API_KEY=

# LinkedIn API Credentials: Create an app at https://www.linkedin.com/developers/
# Request the "w_member_social" permission.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Vercel Cron Job Secret: Generate a random string for security.
# Set this in Vercel Environment Variables.
CRON_SECRET=

# Shared App URL: The public URL of your app (e.g., https://your-app.vercel.app)
# Used for Open Graph tags and LinkedIn link previews.
SHARED_APP_URL="https://ais-pre-k2zyhx7iw4f2x55hvxwlzg-10310046101.europe-west2.run.app"

# Gmail/SMTP Credentials for Newsletter
# You must set these in user secrets for the newsletter to work.
SMTP_USER=
SMTP_PASS=
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465

# Threads API Credentials: Create an app at https://developers.facebook.com/
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
