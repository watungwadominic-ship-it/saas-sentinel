# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_USER_GEMINI_API_KEY: User-provided Gemini API key for client-side calls.
VITE_USER_GEMINI_API_KEY=

# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL="https://dpwkojtfeoxlpyevutfc.supabase.co"

# SUPABASE_KEY: Your Supabase service role or anon key
SUPABASE_KEY="sb_publishable_WumEuqpPeooXrt1nkO9l_w_zWa37BgE"

# NewsAPI Key: Get yours at https://newsapi.org/
NEWS_API_KEY=

# Groq API Key: Get yours at https://console.groq.com/keys
GROQ_API_KEY=

# Social Media API Credentials
# LinkedIn: https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Threads: https://developers.facebook.com/
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# Twitter/X: https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
